{
  "name": "ai-startup-analyzer",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build --concurrency=1",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "db:migrate": "pnpm --filter @ai-analyzer/db migrate",
    "db:generate": "pnpm --filter @ai-analyzer/db generate",
    "db:studio": "pnpm --filter @ai-analyzer/db studio"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "pnpm": {
    "overrides": {
      "lodash": "^4.17.23",
      "multer": "^2.1.1",
      "file-type": "^21.3.2",
      "flatted": "^3.4.2",
      "glob@^10.0.0": "^10.5.0",
      "minimatch@^9.0.0": "^9.0.7",
      "brace-expansion@^1.1.0": "^1.1.13",
      "brace-expansion@^2.0.0": "^2.0.3",
      "picomatch@^2.0.0": "^2.3.2",
      "picomatch@^4.0.0": "^4.0.4",
      "path-to-regexp@^0.1.0": "^0.1.13",
      "handlebars": "^4.7.9",
      "nodemailer": "^8.0.4",
      "@angular-devkit/core>ajv": "^8.18.0",
      "tmp": "^0.2.4",
      "webpack@^5.0.0": "^5.104.0"
    }
  }
}
