# Database (Neon)
# DATABASE_URL: pooled connection string from Neon for the running app.
# DIRECT_DATABASE_URL: direct connection string from the same Neon branch for Prisma migrations.
# Neon org: org-round-rain-85943923
# Neon project: tiny-mud-62618983
DATABASE_URL="postgresql://neondb_owner:<password>@ep-<pooled-endpoint>-pooler.<region>.aws.neon.tech/neondb?sslmode=require"
DIRECT_DATABASE_URL="postgresql://neondb_owner:<password>@ep-<direct-endpoint>.<region>.aws.neon.tech/neondb?sslmode=require"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
# Set REDIS_PASSWORD for production deployments.

# AI APIs
GEMINI_API_KEY="your-gemini-api-key"
OPENROUTER_API_KEY="your-openrouter-api-key"

# JWT — MUST be a strong random string in production
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4000/auth/google/callback"

# Grounding flags (default: enabled)
ENABLE_AI_GROUNDING="true"
ENABLE_RULE_GROUNDING="true"

# App
NODE_ENV="development"
BACKEND_PORT=4000
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:4000"
