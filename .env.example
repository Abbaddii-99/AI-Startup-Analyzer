# Database
# For development: DB_PROVIDER=sqlite DATABASE_URL="file:./packages/db/prisma/dev.db"
# For production: DB_PROVIDER=postgresql DATABASE_URL="postgresql://user:pass@host:5432/ai_analyzer"
DB_PROVIDER="sqlite"
DATABASE_URL="file:./packages/db/prisma/dev.db"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# AI APIs
GEMINI_API_KEY="your-gemini-api-key"
OPENROUTER_API_KEY="your-openrouter-api-key"

# JWT — MUST be a strong random string in production
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4000/auth/google/callback"

# Grounding flags (default: enabled)
ENABLE_AI_GROUNDING="true"
ENABLE_RULE_GROUNDING="true"

# App
NODE_ENV="development"
BACKEND_PORT=4000
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:4000"
