{
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "env": {
    "browser": true,
    "es2020": true
  },
  "rules": {
    "no-unused-vars": "warn"
  },
  "ignores": [
    ".next/**",
    "node_modules/**",
    ".turbo/**",
    "dist/**",
    "coverage/**"
  ]
}
